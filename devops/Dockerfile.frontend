FROM node:20-slim AS builder
WORKDIR /app
COPY ui/package.json ui/bun.lock* ui/package-lock.json* ./
RUN npm install --legacy-peer-deps
COPY ui/ ./
RUN npm run build

FROM node:20-slim
WORKDIR /app
COPY --from=builder /app ./
EXPOSE 8080
CMD ["npm", "run", "preview", "--", "--host", "0.0.0.0", "--port", "8080"]
