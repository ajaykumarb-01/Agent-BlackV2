# ─── Agent Black VPS Environment ──────────────────────────────────────────────
# Copy this to .env on your VPS and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Your GitHub username or org (used to pull images from GHCR)
GITHUB_OWNER=your-github-username

# ── LLM API Keys (at least one required) ──────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# ── Networking ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Frontend ──────────────────────────────────────────────────────────────────
# Point this to your VPS public IP or domain, e.g. http://your-vps-ip:8000/api
VITE_API_URL=http://localhost:8000/api

# ── Optional ──────────────────────────────────────────────────────────────────
# SEMANTIC_SCHOLAR_API_KEY=...
# COMPOSE_PROJECT_NAME=agent-black
